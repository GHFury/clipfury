{
  "name": "clipfury",
  "version": "0.1.0",
  "description": "Automatic Marvel Snap clip capture \u2014 never miss a snap",
  "main": "src/main/index.js",
  "author": "SnapFury",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "cross-env NODE_ENV=development electron .",
    "build": "electron-builder --win",
    "build:unsigned": "electron-builder --win --config.win.certificateFile=null"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "ffmpeg-static": "^5.2.0",
    "obs-websocket-js": "^5.0.5"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.snapfury.clipfury",
    "productName": "ClipFury",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ClipFury"
    },
    "extraResources": [
      {
        "from": "models/",
        "to": "models/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ]
  }
}